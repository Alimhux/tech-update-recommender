# API-ключ LLM-провайдера (выберите один):
# GEMINI_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here
# TUR_LLM_API_KEY=your_key_here

# Для OpenAI-совместимых провайдеров (Yandex Cloud, DeepSeek и др.):
# OPENAI_API_BASE=https://ai.api.cloud.yandex.net/v1

# Модель по умолчанию (необязательно, можно передать через --llm-model):
# TUR_LLM_MODEL=gemini/gemini-2.0-flash

# Путь к syft (если не в PATH):
# TUR_SYFT_PATH=/usr/local/bin/syft
